<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Задаем прозрачный холст размера 108dp х 108dp для сохранения правильного intrinsic размера всего слоя (устраняет дёргание и смещение в HyperOS/MIUI) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <size
                android:width="108dp"
                android:height="108dp" />
        </shape>
    </item>

    <!-- Идеально центрированная иконка с фиксированным размером 66dp внутри безопасной зоны (safe zone) -->
    <item
        android:width="66dp"
        android:height="66dp"
        android:gravity="center"
        android:drawable="@drawable/root_icon_fg_1779790130213" />
</layer-list>

